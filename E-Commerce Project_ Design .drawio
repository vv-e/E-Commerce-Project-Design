<mxfile host="app.diagrams.net">
  <diagram name="Page-1" id="NNZnRvWaIP5trw9sIZ81">
    <mxGraphModel dx="1768" dy="1184" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml Online_Marketplace_ERD\n\n&#39; ─────────────────────────────────────────────\n&#39; Styling\n&#39; ─────────────────────────────────────────────\nskinparam linetype ortho\nskinparam roundcorner 8\nskinparam classAttributeIconSize 0\nskinparam classFontSize 13\nskinparam classHeaderBackgroundColor #2C3E50\nskinparam classHeaderFontColor #FFFFFF\nskinparam classBorderColor #566573\nskinparam classBackgroundColor #F2F3F4\nskinparam ArrowColor #2C3E50\nskinparam ArrowThickness 1.5\nskinparam NoteBackgroundColor #FEF9E7\nskinparam NoteBorderColor #F0B429\n\nhide empty methods\n\n&#39; ─────────────────────────────────────────────\n&#39; SUPERTYPE\n&#39; ─────────────────────────────────────────────\n\nentity User &lt;&lt; (S, #3498DB) Strong &gt;&gt; {\n  * user_id       : INT &lt;&lt;PK&gt;&gt;\n  --\n  * email         : VARCHAR(255) &lt;&lt;UQ&gt;&gt;\n  * password_hash : VARCHAR(255)\n  * first_name    : VARCHAR(100)\n  * last_name     : VARCHAR(100)\n    phone         : VARCHAR(20)\n  * created_at    : DATETIME\n    last_login    : DATETIME\n}\n\n&#39; ─────────────────────────────────────────────\n&#39; SUBTYPES\n&#39; ─────────────────────────────────────────────\n\nentity Customer &lt;&lt; (S, #2ECC71) Subtype &gt;&gt; {\n  * user_id          : INT &lt;&lt;PK, FK&gt;&gt;\n  --\n    shipping_address : VARCHAR(500)\n    billing_address  : VARCHAR(500)\n}\n\nentity Seller &lt;&lt; (S, #2ECC71) Subtype &gt;&gt; {\n  * user_id           : INT &lt;&lt;PK, FK&gt;&gt;\n  --\n  * store_name        : VARCHAR(255) &lt;&lt;UQ&gt;&gt;\n    store_description : TEXT\n    rating            : DECIMAL(3,2)\n}\n\n&#39; ─────────────────────────────────────────────\n&#39; CORE ENTITIES\n&#39; ─────────────────────────────────────────────\n\nentity Category &lt;&lt; (S, #3498DB) Strong &gt;&gt; {\n  * category_id : INT &lt;&lt;PK&gt;&gt;\n  --\n  * name        : VARCHAR(100) &lt;&lt;UQ&gt;&gt;\n    description : TEXT\n}\n\nentity Product &lt;&lt; (S, #3498DB) Strong &gt;&gt; {\n  * product_id  : INT &lt;&lt;PK&gt;&gt;\n  --\n  * seller_id   : INT &lt;&lt;FK&gt;&gt;\n  * category_id : INT &lt;&lt;FK&gt;&gt;\n  * name        : VARCHAR(255)\n    description : TEXT\n  * price       : DECIMAL(10,2)\n  * created_at  : DATETIME\n  * is_active   : BOOLEAN\n}\n\nentity Transaction &lt;&lt; (S, #3498DB) Strong &gt;&gt; {\n  * transaction_id   : INT &lt;&lt;PK&gt;&gt;\n  --\n  * customer_id      : INT &lt;&lt;FK&gt;&gt;\n  * transaction_date : DATETIME\n  * status           : ENUM(pending, completed, cancelled, refunded)\n  * total_amount     : DECIMAL(10,2)\n  * shipping_address : VARCHAR(500)\n}\n\n&#39; ─────────────────────────────────────────────\n&#39; WEAK ENTITIES\n&#39; ─────────────────────────────────────────────\n\nentity Inventory &lt;&lt; (W, #E74C3C) Weak &gt;&gt; {\n  * product_id        : INT &lt;&lt;PK, FK&gt;&gt;\n  --\n  * quantity_in_stock : INT\n    restock_threshold : INT\n  * last_updated      : DATETIME\n}\n\nentity TransactionItem &lt;&lt; (W, #E74C3C) Weak &gt;&gt; {\n  * transaction_id : INT &lt;&lt;PK, FK&gt;&gt;\n  * product_id     : INT &lt;&lt;PK, FK&gt;&gt;\n  --\n  * quantity   : INT\n  * unit_price : DECIMAL(10,2)\n}\n\nentity Review &lt;&lt; (W, #E74C3C) Weak &gt;&gt; {\n  * customer_id : INT &lt;&lt;PK, FK&gt;&gt;\n  * product_id  : INT &lt;&lt;PK, FK&gt;&gt;\n  --\n  * rating      : INT\n    title       : VARCHAR(255)\n    body        : TEXT\n  * created_at  : DATETIME\n}\n\n&#39; ─────────────────────────────────────────────\n&#39; RELATIONSHIPS\n&#39; ─────────────────────────────────────────────\n\n&#39; Supertype / Subtype (ISA)\nUser ||--o| Customer : \&quot;is a\&quot;\nUser ||--o| Seller   : \&quot;is a\&quot;\n\n&#39; Seller lists Products\nSeller ||--o{ Product : \&quot;lists\&quot;\n\n&#39; Product belongs to Category\nCategory ||--o{ Product : \&quot;categorizes\&quot;\n\n&#39; Product has one Inventory record (weak)\nProduct ||--|| Inventory : \&quot;has\&quot;\n\n&#39; Customer places Transactions\nCustomer ||--o{ Transaction : \&quot;places\&quot;\n\n&#39; Transaction broken into line items (weak)\nTransaction ||--|{ TransactionItem : \&quot;contains\&quot;\n\n&#39; TransactionItem references Product\nProduct ||--o{ TransactionItem : \&quot;refers to\&quot;\n\n&#39; Customer writes Reviews (weak)\nCustomer ||--o{ Review : \&quot;writes\&quot;\n\n&#39; Product receives Reviews\nProduct ||--o{ Review : \&quot;receives\&quot;\n\n&#39; ─────────────────────────────────────────────\n&#39; NOTES\n&#39; ─────────────────────────────────────────────\n\nnote top of User\n  &lt;b&gt;Supertype&lt;/b&gt;\n  A User can be a Customer,\n  a Seller, or both.\n  Subtypes share user_id (PK).\nend note\n\nnote right of TransactionItem\n  &lt;b&gt;Weak Entity&lt;/b&gt;\n  Composite PK:\n  (transaction_id, product_id)\n  unit_price is a snapshot —\n  price may change over time.\nend note\n\nnote right of Inventory\n  &lt;b&gt;Weak Entity&lt;/b&gt;\n  Existence depends entirely\n  on a Product record.\nend note\n\nnote bottom of Transaction\n  shipping_address stored as\n  a snapshot here — Customer\n  address can change post-purchase.\nend note\n\nnote right of Review\n  &lt;b&gt;Weak Entity&lt;/b&gt;\n  Composite PK:\n  (customer_id, product_id)\n  A customer can only review\n  a given product once.\nend note\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="zr1Kf6a5NDoYooOEkv-d-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="920" width="1710" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
